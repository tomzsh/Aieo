# --- Public site (optional) ---
# Footer / landing GitHub link (default: https://github.com/tomzsh/Aieo)
# NEXT_PUBLIC_GITHUB_URL=https://github.com/tomzsh/Aieo

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# At-rest encryption for WP app passwords & LLM API keys (recommended)
# 64 hex chars (32 bytes) OR any passphrase (hashed with SHA-256)
# openssl rand -hex 32
# AIEO_ENCRYPTION_KEY=
# If unset, a key is derived from SUPABASE_SERVICE_ROLE_KEY (still encrypts).

# LLM — default provider: xAI Grok
XAI_API_KEY=xai-...
# XAI_BASE_URL=https://api.x.ai/v1

# Optional first-party
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=   # OpenAI-compatible proxy
GOOGLE_API_KEY=
# GOOGLE_BASE_URL=

# Third-party / gateways
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
MISTRAL_API_KEY=
FIREWORKS_API_KEY=
PERPLEXITY_API_KEY=
LITELLM_API_KEY=
# LITELLM_BASE_URL=http://127.0.0.1:4000/v1

# Local gateways
# OmniRoute — https://github.com/diegosouzapw/OmniRoute (default port 20128)
OMNIROUTE_BASE_URL=http://127.0.0.1:20128/v1
# OMNIROUTE_API_KEY=   # optional dashboard key from OmniRoute

OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_API_KEY=ollama

LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1
# LMSTUDIO_API_KEY=

# Custom OpenAI-compatible endpoint (global fallback)
# CUSTOM_LLM_BASE_URL=https://your-gateway.example.com/v1
# CUSTOM_LLM_API_KEY=
# LLM_BASE_URL=
# LLM_API_KEY=
# LLM_TIMEOUT_MS=300000
